function defNewStart(){
  if(!jobs.length)return dk(new Date());
  return aD(jobs.reduce((m,j)=>j.end>m?j.end:m,jobs[0].end),1);
}

function ff(id,lb,val,tp,ph,req){
  const r=req?'<span style="color:#dc2626;margin-left:3px;">*</span>':'';
  const ds=tp==='date'?'color-scheme:light;':'';
  return`<div class="ff"><label class="flbl">${lb}${r}</label>
    <input class="finp" type="${tp}" id="${id}" value="${tp!=='number'?esc(String(val||'')):val||''}" placeholder="${ph||''}" style="${ds}"/>
  </div>`;
}

