#hdr{background:#ffffff;border-bottom:1px solid var(--brd);padding:0 24px;display:flex;align-items:center;height:64px;position:sticky;top:0;z-index:100;box-shadow:0 2px 16px rgba(30,107,212,.12);}
.hlogo{width:40px;height:40px;background:var(--grd);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;box-shadow:0 0 15px rgba(30,107,212,.28);}
.htitle{color:var(--txt);font-size:15px;font-weight:900;}
.hsub{color:var(--mut);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;}
.rbadge{padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;border-width:1px;border-style:solid;}
