.mbody{padding:24px;}
.albox{background:#ffffff;border:1px solid var(--brd);border-radius:14px;padding:44px 48px;width:400px;max-width:92vw;box-shadow:0 8px 40px rgba(30,107,212,.14);position:relative;}
.altop{position:absolute;top:0;left:48px;right:48px;height:2px;background:var(--grd);border-radius:0 0 4px 4px;}

/* FORM */
.fgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.ff{display:flex;flex-direction:column;gap:5px;}
.flbl{color:var(--sub);font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;}
.finp{background:#f5f9ff;border:1px solid var(--brd);border-radius:6px;color:var(--txt);padding:9px 12px;font-size:13px;outline:none;width:100%;}
