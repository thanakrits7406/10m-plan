*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--txt);font-family:'Segoe UI',system-ui,sans-serif;min-height:100vh;font-size:14px;line-height:1.5;}
::-webkit-scrollbar{width:6px;height:6px;}::-webkit-scrollbar-track{background:#ddeffa;}::-webkit-scrollbar-thumb{background:#9ac4e0;border-radius:3px;}
input,select,textarea,button{font-family:inherit;}

