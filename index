/* SUMMARY */
.stitle{color:var(--sub);font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:16px;}

/* FIREBASE STATUS */
#fbst{position:fixed;bottom:18px;right:18px;z-index:500;font-size:11px;font-family:monospace;padding:5px 14px;border-radius:20px;background:rgba(255,255,255,.97);border:1px solid;box-shadow:0 2px 12px rgba(0,0,0,.10);transition:all .5s;}
#fbst.ok{color:#059669;border-color:rgba(5,150,105,.35);}
#fbst.err{color:#dc2626;border-color:rgba(220,38,38,.3);}
#fbst.ld{color:#d97706;border-color:rgba(217,119,6,.3);}

/* CREDIT */
#credit{text-align:center;padding:16px 24px;color:var(--mut);font-size:12px;letter-spacing:1px;border-top:1px solid var(--brd);margin-top:8px;}

/* PRINT HEADER */
#phdr{display:none;background:#0f2540;color:#fff;padding:10px 16px;border-radius:6px;margin-bottom:10px;}
#phdr h1{font-size:16px;color:#7ec8f0;font-weight:900;margin-bottom:2px;}
.psub{font-size:10px;color:#7ab0d0;}
.pmeta{display:flex;justify-content:space-between;margin-top:8px;font-size:10px;color:#6090b0;border-top:1px solid #1e4060;padding-top:6px;}

/* PRINT */
@media print{
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;}
  @page{size:A4 landscape;margin:8mm 10mm;}
  body{background:#fff!important;}
  #hdr,.stats-bar,.tab-bar,#credit,.g-legend,.pbanner,#fbst{display:none!important;}
  .panel{background:#fff!important;border:none!important;padding:0!important;}
  #phdr{display:block!important;}
  #tc-table,#tc-summary{display:none!important;}
  #tc-gantt{display:block!important;}
  #gcon{overflow:visible!important;border:none!important;}
}

/* MOBILE */
@media (max-width:768px){
  #hdr{padding:10px 14px;height:auto;min-height:58px;flex-wrap:wrap;gap:10px;}
  .hsub{display:none;}
  .htitle{font-size:13px;}
  .hlogo{width:34px;height:34px;font-size:18px;}
  #main{padding:14px 12px;}
  .stats-bar{grid-template-columns:repeat(2,1fr);gap:8px;}
  .scard{padding:11px 12px;}
  .snum{font-size:21px;}
  .tab-bar{gap:2px;}
  .tb{padding:9px 12px;font-size:12px;}
  .tab-actions{width:100%;margin-left:0;}
  .panel{padding:14px;}
  .fgrid{grid-template-columns:1fr;}
  .mover{padding:10px;align-items:flex-end;}
  .mbox{max-height:90vh;border-radius:12px 12px 0 0;}
  .albox{width:100%;max-width:100%;padding:32px 20px;}
  .fbar{flex-direction:column;align-items:stretch;}
  .fbar .fi{width:100%;}
  .fbar > div{margin-left:0!important;text-align:left;}
}
</style>
</head>
