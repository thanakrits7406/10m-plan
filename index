.rbadge.viewer{background:rgba(16,185,129,.1);color:#059669;border-color:rgba(16,185,129,.3);}
.btn-alog{background:rgba(30,107,212,.1);color:#1e6bd4;border:1px solid rgba(30,107,212,.3);border-radius:20px;padding:6px 14px;font-size:12px;font-weight:700;cursor:pointer;}
.hdate{color:#1e4d80;font-size:11px;font-weight:600;font-variant-numeric:tabular-nums;}
.hsync{color:var(--fnt);font-size:10px;}

/* MAIN */
#main{padding:24px;max-width:1500px;margin:0 auto;}

/* STATS */
.stats-bar{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:24px;}
