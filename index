<script>
/* ═══════════════════════════════════════════════════════
   FIREBASE CONFIGURATION
═══════════════════════════════════════════════════════ */
const FB={apiKey:"AIzaSyAad7GNxjfz3nzPeFtBkhB16fO54QAKmOw",authDomain:"fab-checklist-workshop.firebaseapp.com",databaseURL:"https://fab-checklist-workshop-default-rtdb.firebaseio.com",projectId:"fab-checklist-workshop",storageBucket:"fab-checklist-workshop.firebasestorage.app",messagingSenderId:"80900940748",appId:"1:80900940748:web:0ab64b61d5bcc200fdf369"};
firebase.initializeApp(FB);
const db=firebase.database();
const JR=db.ref('lathe10m/jobs');
const SR=db.ref('lathe10m/settings');

/* ═══════════════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════════════ */
const _a=atob('d29ya3Nob3AyMDI2');
const DEF_AREAS=["ช่างกลึงที่ 1","ช่างกลึงที่ 2","ช่างกลึงที่ 3","งานพิเศษ","งานซ่อมบำรุง","งานเร่งด่วน","ทั่วไป"];
const STS=[{v:"pending",lb:"รอดำเนินการ",c:"#94a3b8"},{v:"in-progress",lb:"กำลังดำเนินการ",c:"#f59e0b"},{v:"completed",lb:"เสร็จสิ้น",c:"#10b981"},{v:"delayed",lb:"ล่าช้า",c:"#ef4444"}];
const MTs=["ม.ค.","ก.พ.","มี.ค.","เม.ย.","พ.ค.","มิ.ย.","ก.ค.","ส.ค.","ก.ย.","ต.ค.","พ.ย.","ธ.ค."];
const MTl=["มกราคม","กุมภาพันธ์","มีนาคม","เมษายน","พฤษภาคม","มิถุนายน","กรกฎาคม","สิงหาคม","กันยายน","ตุลาคม","พฤศจิกายน","ธันวาคม"];
const DT=["อา","จ","อ","พ","พฤ","ศ","ส"];
let role='viewer',jobs=[],areas=[...DEF_AREAS],curTab='gantt';
let _pc=null,_efk=null,_eos=null,_dfk=null,_aei=null;
let tQ='',tA='',tS='';

/* ═══════════════════════════════════════════════════════
   WORKING DAY ENGINE
═══════════════════════════════════════════════════════ */
const SAT_OFF_FIXED=new Set(["2026-05-16","2026-05-30","2026-06-06"]);
const SAT_OFF_REF=new Date("2026-06-20T00:00:00");
function dk(d){const t=new Date(d);return`${t.getFullYear()}-${("0"+(t.getMonth()+1)).slice(-2)}-${("0"+t.getDate()).slice(-2)}`;}
function isWD(date){
  const d=new Date(date);d.setHours(0,0,0,0);
  const w=d.getDay();
  if(w===0)return false;
  if(w===6){
    if(SAT_OFF_FIXED.has(dk(d)))return false;
    const diff=Math.round((d-SAT_OFF_REF)/86400000);
    if(diff<0)return true;
    return diff%14!==0;
  }
  return true;
}
function cWDs(s,e){let d=new Date(s);d.setHours(0,0,0,0);const en=new Date(e);en.setHours(0,0,0,0);let c=0;while(d<=en){if(isWD(d))c++;d.setDate(d.getDate()+1);}return c;}
function aD(ds,n){const d=new Date(ds);d.setDate(d.getDate()+n);return dk(d);}
function dD(a,b){return Math.round((new Date(b)-new Date(a))/86400000);}
const fD=s=>{if(!s)return"—";const d=new Date(s);return`${d.getDate()} ${MTs[d.getMonth()]} ${d.getFullYear()}`;};
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

/* ═══════════════════════════════════════════════════════
   FIREBASE LISTENERS
═══════════════════════════════════════════════════════ */
function setFbSt(s){const e=document.getElementById('fbst');if(!e)return;e.className=s;if(s==='ok'){e.textContent='● Firebase เชื่อมต่อแล้ว';setTimeout(()=>{e.style.opacity='0';},4000);}else if(s==='err'){e.textContent='✕ Firebase ขาดการเชื่อมต่อ';e.style.opacity='1';}else{e.textContent='⟳ กำลังเชื่อมต่อ...';e.style.opacity='1';}}

window.addEventListener('DOMContentLoaded',()=>{
  updDate();renderBadge();renderHActs();renderTActs();
  setInterval(updDate,60000);

  SR.on('value',(snap)=>{
    const d=snap.val();
    if(d&&d.areas){areas=Array.isArray(d.areas)?d.areas:Object.values(d.areas);}
    else{SR.set({areas:DEF_AREAS});areas=[...DEF_AREAS];}
    if(document.getElementById('newarea')){_aei=null;renderAreas();}
    if(curTab==='table')renderTable();
  },(err)=>{console.error('Settings listener error:',err);});

  JR.once('value').then(snap=>{
    if(!snap.exists()){
      const updates={};
      INIT.forEach(j=>{const key=JR.push().key;updates[key]={...j,createdAt:Date.now()};});
      return JR.update(updates);
    }
  }).catch(e=>console.error('Seed check failed:',e)).finally(()=>{
    JR.on('value',(snap)=>{
      const d=snap.val();
      jobs=d?Object.entries(d).map(([k,j])=>({...j,fk:k})).sort((a,b)=>a.start.localeCompare(b.start)):[];
      setFbSt('ok');
      renderAll();
      const now=new Date(),si=document.getElementById('hsync');
      if(si)si.textContent='sync '+now.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
    },(err)=>{
      setFbSt('err');
      console.error('Jobs listener error:',err);
      const el=document.getElementById('tc-gantt');
      if(el&&!jobs.length)el.innerHTML='<div style="text-align:center;color:#dc2626;padding:60px;"><div style="font-size:48px;margin-bottom:12px;">⚠</div>'
        +'<div style="font-weight:700;margin-bottom:8px;">ไม่สามารถเชื่อมต่อฐานข้อมูลได้ (Permission Denied)</div>'
        +'<div style="color:#5082a8;font-size:12px;max-width:480px;margin:0 auto;line-height:1.8;">กรุณาตรวจสอบ Firebase Realtime Database Rules ให้อนุญาต .read และ .write<br>(Firebase Console → Realtime Database → Rules)</div></div>';
    });
  });

  db.ref('.info/connected').on('value',(snap)=>{
    if(snap.val())setFbSt('ok');else setFbSt('err');
  });
});

function updDate(){const now=new Date(),e=document.getElementById('hdate');if(e)e.textContent=`${now.getDate()} ${MTs[now.getMonth()]} ${now.getFullYear()}`;}

/* ═══════════════════════════════════════════════════════
   AUTH
═══════════════════════════════════════════════════════ */
function openLogin(){
  document.getElementById('mr').innerHTML=`
  <div class="mover" onclick="if(event.target===this)closeM()">
    <div class="albox">
      <div class="altop"></div>
      <div style="text-align:center;margin-bottom:28px;">
