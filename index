  </div>`).join('');
}

/* GANTT */
const CW=36,RH=54,LW=300;
function renderGantt(printMode=false){
  const el=document.getElementById('tc-gantt');if(!el)return;
  if(!jobs.length){el.innerHTML='<div style="text-align:center;color:var(--mut);padding:60px;"><div style="font-size:48px;margin-bottom:12px;">📅</div>ยังไม่มีข้อมูลงาน</div>';return;}
  const today=dk(new Date());
  const ms=jobs.reduce((m,j)=>j.start<m?j.start:m,jobs[0].start);
  const me=jobs.reduce((m,j)=>j.end>m?j.end:m,jobs[0].end);

  const CWx=printMode?18:CW, RHx=printMode?36:RH, LWx=printMode?170:LW;
  const padS=printMode?1:3, padE=printMode?1:14;
  const stH=printMode?'':'position:sticky;top:0;z-index:20;';
  const stL=printMode?'':'position:sticky;left:0;z-index:21;';
  const stR=printMode?'':'position:sticky;left:0;z-index:10;';
  const rpad=printMode?10:16;

  const days=[],idxMap={},months=[];
  let c=new Date(aD(ms,-padS));const en=new Date(aD(me,padE));
  while(c<=en){days.push(dk(c));c.setDate(c.getDate()+1);}
  days.forEach((s,i)=>idxMap[s]=i);
  days.forEach(ds=>{
    const dt=new Date(ds),k=`${dt.getFullYear()}-${dt.getMonth()}`;
    const l=months[months.length-1];
    if(!l||l.k!==k)months.push({k,lb:`${MTl[dt.getMonth()]} ${dt.getFullYear()}`,cnt:1});else l.cnt++;
  });
  const tdi=idxMap[today]??-1,totalW=LWx+days.length*CWx;

  /* MONTH HEADER */
  const mH=months.map(m=>`<div style="width:${m.cnt*CWx}px;flex-shrink:0;background:#e8f2ff;border-left:2px solid rgba(30,107,212,.22);display:flex;align-items:center;padding:0 8px;color:#1e6bd4;font-size:${printMode?11:13}px;font-weight:700;overflow:hidden;white-space:nowrap;">${m.lb}</div>`).join('');

  /* DAY HEADER */
  const dH=days.map((ds,i)=>{
    const d=new Date(ds),off=!isWD(d),itd=ds===today,mon=d.getDay()===1;
    const bg=itd?'rgba(239,68,68,.18)':off?'rgba(180,210,240,.18)':'#e8f2ff';
    const bl=mon?'2px solid #88b8dc':'1px solid #d5e8f8';
    const nc=itd?'#ef4444':off?'#94a3b8':mon?'#1e6bd4':'#475569';
    const dc=itd?'#ef4444':off?'#b0c8d8':'#64748b';
    return`<div style="width:${CWx}px;flex-shrink:0;background:${bg};border-left:${bl};display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;">
      <div style="color:${nc};font-size:${printMode?9:10}px;font-weight:${itd?900:mon?700:400};line-height:1;">${d.getDate()}</div>
      <div style="color:${dc};font-size:${printMode?7:8}px;line-height:1;">${DT[d.getDay()]}</div>
    </div>`;
  }).join('');

  /* ROWS */
  const rowsH=jobs.map((j,ri)=>{
    const st=STS.find(s=>s.v===j.status),si=idxMap[j.start],ei=idxMap[j.end];
    const isAct=j.start<=today&&j.end>=today,wds=cWDs(j.start,j.end);
    const rBg=isAct?'rgba(30,107,212,.08)':ri%2===0?'rgba(240,250,255,.75)':'transparent';
    const lBg=isAct?'#dff0ff':ri%2===0?'#f3f9ff':'#f8fbff';
    let barH='';
    if(si!==undefined){
      const bl=si*CWx+2,bw=((ei===undefined?days.length-1:ei)-si+1)*CWx-4,sc=st?.c||'#94a3b8';
      const bpad=printMode?6:10,btop=printMode?5:8,bh=RHx-(printMode?10:16);
      barH=`<div style="position:absolute;left:${bl}px;width:${bw}px;top:${btop}px;height:${bh}px;
        background:linear-gradient(90deg,${sc}28,${sc}40);border:1.5px solid ${sc}60;
        border-radius:6px;display:flex;align-items:center;padding-left:${bpad}px;overflow:hidden;z-index:2;">
        ${bw>(printMode?42:80)?`<span style="color:${sc};font-size:${printMode?10:12}px;font-weight:800;white-space:nowrap;">${esc(j.partName)}</span>`:''}
        ${(!printMode&&bw>260)?`<span style="color:${sc}80;font-size:10px;margin-left:10px;white-space:nowrap;">${fD(j.start)} – ${fD(j.end)}</span>`:''}
      </div>`;
    }
    const bgC=days.map((ds,i)=>{
      const d=new Date(ds),off=!isWD(d),mon=d.getDay()===1,itd=ds===today;
      return`<div style="position:absolute;left:${i*CWx}px;top:0;width:${CWx}px;height:${RHx}px;background:${itd?'rgba(239,68,68,.05)':off?'rgba(180,210,240,.12)':'transparent'};${mon?'border-left:1px solid #d5e8f8':''}"></div>`;
    }).join('');
    const tLine=tdi!==-1?`<div style="position:absolute;left:${tdi*CWx+CWx/2}px;top:0;width:2px;height:${RHx}px;background:rgba(239,68,68,.5);z-index:3;pointer-events:none;"></div>`:'';
    const admB=(role==='admin'&&!printMode)?`<div style="display:flex;gap:4px;flex-shrink:0;margin-left:6px;">
      <button class="bico be" onclick="openJob('${j.fk}')" title="แก้ไข">✏</button>
      <button class="bico bd" onclick="openDel('${j.fk}')" title="ลบ">🗑</button>
    </div>`:'';
    const pbi=printMode?'page-break-inside:avoid;':'';
    return`<div style="display:flex;height:${RHx}px;border-bottom:1px solid #d5e8f8;background:${rBg};${pbi}">
      <div style="width:${LWx}px;flex-shrink:0;${stR}background:${lBg};border-right:1px solid #b8d0ea;padding:0 ${rpad}px;display:flex;align-items:center;gap:8px;">
        <div style="width:4px;height:${RHx-20}px;background:${st?.c||'#5082a8'};border-radius:2px;flex-shrink:0;"></div>
        <div style="overflow:hidden;flex:1;">
          <div style="color:#1a3050;font-size:${printMode?11:13}px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(j.partName)}</div>
          <div style="color:#2d5a8a;font-size:${printMode?9:10}px;white-space:nowrap;display:flex;gap:6px;margin-top:2px;overflow:hidden;">
            <span style="color:#1e6bd4;">${esc(j.jobNo||'—')}</span>
            <span style="color:#5b7fa0;">${esc(j.area)}</span>
            <span style="color:#6890b0;">${wds}${printMode?'วัน':' วันทำงาน'}</span>
          </div>
        </div>
        ${admB}
      </div>
      <div style="flex:1;position:relative;overflow:hidden;">${bgC}${barH}${tLine}</div>
    </div>`;
  }).join('');

  const gT=tdi!==-1?`
    <div style="position:absolute;left:${LWx+tdi*CWx+CWx/2}px;top:0;bottom:0;width:2px;background:rgba(239,68,68,.12);z-index:0;pointer-events:none;"></div>
    <div style="position:absolute;left:${LWx+tdi*CWx+CWx/2-22}px;top:${printMode?52:72}px;background:#dc2626;color:#fff;font-size:9px;font-weight:800;padding:2px 5px;border-radius:3px;z-index:25;pointer-events:none;letter-spacing:.5px;">TODAY</div>`:'';

  /* HEADER */
  const head=`<div style="${stH}display:flex;">
    <div style="width:${LWx}px;flex-shrink:0;${stL}background:#e8f2ff;border-right:1px solid #b8d0ea;">
      <div style="height:${printMode?28:34}px;padding:0 ${rpad}px;display:flex;align-items:center;border-bottom:1px solid #c0d8f0;">
        <span style="color:#1e6bd4;font-size:${printMode?8:9}px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;">10M LATHE — GANTT CHART</span>
      </div>
      <div style="height:${printMode?26:32}px;padding:0 ${rpad}px;display:flex;align-items:center;border-bottom:2px solid #a0c4e0;">
        <span style="color:#5a82a8;font-size:${printMode?9:10}px;">ชิ้นงาน / เลขงาน / พื้นที่</span>
      </div>
    </div>
    <div style="flex:1;">
      <div style="display:flex;height:${printMode?28:34}px;background:#e8f2ff;border-bottom:1px solid #d5e8f8;">${mH}</div>
      <div style="display:flex;height:${printMode?26:32}px;background:#e8f2ff;border-bottom:2px solid #b8d0ea;">${dH}</div>
    </div>
  </div>`;

  if(printMode){
    el.innerHTML=`<div id="gcon" style="overflow:visible;width:${totalW}px;position:relative;">${head}${rowsH}${gT}</div>`;
    return;
  }

  const leg=`<div class="g-legend">
    <span style="color:var(--sub);font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-right:4px;">คำอธิบาย:</span>
    ${STS.map(s=>`<div class="leg"><div class="legdot" style="background:${s.c};"></div>${s.lb}</div>`).join('')}
    <div class="leg"><div class="legdot" style="background:rgba(239,68,68,.22);border:1px solid rgba(239,68,68,.4);"></div>วันนี้</div>
    <div class="leg"><div class="legdot" style="background:rgba(180,210,240,.4);border:1px solid rgba(150,195,230,.6);"></div>วันหยุด</div>
  </div>`;
  const pb=role==='admin'?`<div class="pbanner">🖨️ กดปุ่ม <strong style="color:#059669;">พิมพ์ Gantt</strong> ด้านบนขวาเพื่อพิมพ์ A4 แนวนอน — หากตารางกว้างเกิน 1 หน้า ให้เลือก "Fit to printable area" / "Scale: Shrink to fit" ในหน้าตั้งค่าพิมพ์</div>`:'';
  el.innerHTML=pb+leg+`
    <div id="gcon" style="overflow:auto;border:1px solid #b8d0ea;border-radius:8px;box-shadow:0 2px 12px rgba(30,107,212,.08);">
      <div style="min-width:${totalW}px;position:relative;">${head}${rowsH}${gT}</div>
    </div>`;
  if(tdi>0)setTimeout(()=>{const g=document.getElementById('gcon');if(g)g.scrollLeft=Math.max(0,tdi*CWx-280);},80);
}

/* TABLE */
function renderTable(){
  const el=document.getElementById('tc-table');if(!el)return;
  const today=dk(new Date()),isAdm=role==='admin';
  const vis=jobs.filter(j=>{
    if(tA&&j.area!==tA)return false;if(tS&&j.status!==tS)return false;
    if(tQ){const q=tQ.toLowerCase();return j.partName.toLowerCase().includes(q)||(j.jobNo||'').toLowerCase().includes(q)||(j.mat||'').toLowerCase().includes(q)||(j.area||'').toLowerCase().includes(q);}
    return true;
  });
  const aO=areas.map(a=>`<option value="${esc(a)}"${a===tA?' selected':''}>${esc(a)}</option>`).join('');
  const sO=STS.map(s=>`<option value="${s.v}"${s.v===tS?' selected':''}>${s.lb}</option>`).join('');
  const rows=vis.map((j,vi)=>{
    const pN=jobs.indexOf(j)+1,isAct=j.start<=today&&j.end>=today;
    const wds=cWDs(j.start,j.end),st=STS.find(s=>s.v===j.status)||STS[0];
    const rC=isAct?'ar':vi%2===0?'er':'';
    const stC=isAdm
      ?`<select class="ssel" style="color:${st.c};" onchange="chgSt('${j.fk}',this.value)">${STS.map(s=>`<option value="${s.v}"${s.v===j.status?' selected':''}>${s.lb}</option>`).join('')}</select>`
      :`<span class="sbadge" style="background:${st.c}18;color:${st.c};border-color:${st.c}40;">${st.lb}</span>`;
    const aA=isAdm?`<td><div style="display:flex;gap:4px;">
      <button class="bico be" onclick="openJob('${j.fk}')" title="แก้ไข">✏</button>
      <button class="bico bd" onclick="openDel('${j.fk}')" title="ลบ">🗑</button>
    </div></td>`:'';
    return`<tr class="${rC}">
      <td style="color:#2d5a8a;text-align:center;font-variant-numeric:tabular-nums;">${pN}${isAct?'<span style="margin-left:4px;color:#d97706;font-size:9px;">●</span>':''}</td>
      <td style="font-family:monospace;color:#1e6bd4;font-size:12px;font-weight:600;">${esc(j.jobNo||'—')}</td>
      <td style="font-weight:700;color:#1a3050;">${esc(j.partName)}</td>
      <td style="font-family:monospace;color:#0369a1;font-size:12px;">${esc(j.drawNo||'—')}</td>
      <td style="font-family:monospace;font-size:12px;">${esc(j.mat||'—')}</td>
      <td style="font-family:monospace;font-size:12px;">${esc(j.dia||'—')}</td>
      <td style="font-family:monospace;font-size:12px;">${j.len?esc(j.len)+' mm':'—'}</td>
      <td style="text-align:center;">${j.qty||1}</td>
      <td><span class="abadge">${esc(j.area)}</span></td>
      <td style="white-space:nowrap;font-variant-numeric:tabular-nums;">${fD(j.start)}</td>
      <td style="white-space:nowrap;font-variant-numeric:tabular-nums;">${fD(j.end)}</td>
      <td style="text-align:center;color:#1e6bd4;font-weight:800;font-variant-numeric:tabular-nums;">${wds}</td>
      <td>${stC}</td>
      <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px;color:#2d5a8a;">${esc(j.notes||'—')}</td>
      ${aA}
    </tr>`;
  }).join('');
  el.innerHTML=`
    <div class="fbar">
      <input type="text" placeholder="🔍 ค้นหาชื่อชิ้นงาน / เลขงาน / พื้นที่..." value="${esc(tQ)}" oninput="tQ=this.value;renderTable();" class="fi" style="min-width:280px;"/>
      <select class="fi" onchange="tA=this.value;renderTable();"><option value="">📍 ทุกพื้นที่</option>${aO}</select>
      <select class="fi" onchange="tS=this.value;renderTable();"><option value="">📊 ทุกสถานะ</option>${sO}</select>
      <div style="color:#2d5a8a;font-size:12px;margin-left:auto;">${vis.length}/${jobs.length} รายการ</div>
    </div>
    <div class="twrap">
      <table>
        <thead><tr>
          <th>#</th><th>เลขที่งาน</th><th>ชื่อชิ้นงาน</th><th>เลขที่แบบ</th>
          <th>วัสดุ</th><th>∅ (mm)</th><th>ยาว (mm)</th><th>จำนวน</th>
          <th>พื้นที่</th><th>วันเริ่มต้น</th><th>วันสิ้นสุด</th><th>วันทำงาน</th>
          <th>สถานะ</th><th>หมายเหตุ</th>${isAdm?'<th>จัดการ</th>':''}
        </tr></thead>
        <tbody>${rows||'<tr><td colspan="20" style="padding:48px;text-align:center;color:#2d5a8a;"><div style="font-size:40px;margin-bottom:10px;">🔍</div>ไม่พบข้อมูลที่ตรงกับเงื่อนไข</td></tr>'}</tbody>
      </table>
    </div>`;
}

function chgSt(fk,status){JR.child(fk+'/status').set(status).catch(e=>alert('Error: '+e.message));}

/* SUMMARY */
function renderSummary(){
  const el=document.getElementById('tc-summary');if(!el)return;
  const tot=jobs.length,bySt={},byA={};let wds=0;
  STS.forEach(s=>bySt[s.v]=0);
  jobs.forEach(j=>{bySt[j.status]=(bySt[j.status]||0)+1;byA[j.area]=(byA[j.area]||0)+1;wds+=cWDs(j.start,j.end);});
  const first=jobs[0],last=jobs[jobs.length-1];
  const sBars=STS.map(st=>{const cnt=bySt[st.v]||0,pct=tot?(cnt/tot*100):0;return`
