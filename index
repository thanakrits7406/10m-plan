async function addArea(){
  const inp=document.getElementById('newarea'),val=inp?.value.trim();
  if(!val)return;
  if(areas.includes(val)){alert('Area นี้มีอยู่แล้ว');return;}
  const na=[...areas,val];
  try{await SR.child('areas').set(na);areas=na;_aei=null;renderAreas();}
  catch(e){alert('Error: '+e.message);}
}

async function saveAE(idx){
  const inp=document.getElementById('aei'),val=inp?.value.trim();
  if(!val)return;
  if(areas.some((a,i)=>i!==idx&&a===val)){alert('มีชื่อ Area นี้อยู่แล้ว');return;}
  const na=[...areas];na[idx]=val;
  try{await SR.child('areas').set(na);areas=na;_aei=null;renderAreas();}
  catch(e){alert('Error: '+e.message);}
}

async function delArea(idx){
  if(!confirm(`ลบ Area "${areas[idx]}" หรือไม่?\nงานที่ใช้ Area นี้ยังคงอยู่ แต่ Area จะหายจากตัวเลือก`))return;
  const na=areas.filter((_,i)=>i!==idx);
  try{await SR.child('areas').set(na);areas=na;_aei=null;renderAreas();}
  catch(e){alert('Error: '+e.message);}
}

