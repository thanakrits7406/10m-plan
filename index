textarea.finp{resize:vertical;line-height:1.5;min-height:72px;}
.wbox{margin-top:14px;padding:11px 16px;background:rgba(251,191,36,.09);border:1px solid rgba(217,119,6,.2);border-radius:8px;color:#b45309;font-size:12px;line-height:1.7;}
