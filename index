.fi:focus{border-color:var(--blue);}
.twrap{overflow:auto;border-radius:8px;border:1px solid var(--brd);}
table{width:100%;border-collapse:collapse;min-width:1200px;}
thead th{background:#e8f2ff;color:var(--mut);font-size:10px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;padding:11px 14px;text-align:left;border-bottom:2px solid var(--brd);white-space:nowrap;}
tbody td{padding:9px 14px;border-bottom:1px solid var(--brd2);font-size:13px;color:var(--sub);vertical-align:middle;}
