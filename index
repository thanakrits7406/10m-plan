/* STATS */
function renderStats(){
  const tot=jobs.length,done=jobs.filter(j=>j.status==='completed').length;
  const act=jobs.filter(j=>j.status==='in-progress').length,pend=jobs.filter(j=>j.status==='pending').length;
  const del=jobs.filter(j=>j.status==='delayed').length,wds=jobs.reduce((a,j)=>a+cWDs(j.start,j.end),0);
  const el=document.getElementById('sbar');if(!el)return;
  el.innerHTML=[
    {i:'📋',lb:'งานทั้งหมด',v:tot,c:'#1e6bd4'},{i:'⚙',lb:'กำลังดำเนินการ',v:act,c:'#f59e0b'},
    {i:'✅',lb:'เสร็จสิ้น',v:done,c:'#10b981'},{i:'⏳',lb:'รอดำเนินการ',v:pend,c:'#94a3b8'},
    {i:'⚠',lb:'ล่าช้า',v:del,c:'#ef4444'},{i:'🗓',lb:'วันทำงานรวม',v:wds,c:'#7c3aed',u:'วัน'},
  ].map(c=>`<div class="scard" style="border-top:2px solid ${c.c}40;">
    <div class="slbl">${c.i} ${c.lb}</div>
