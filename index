function updWDS(){
  const s=document.getElementById('js')?.value,e=document.getElementById('je')?.value,w=document.getElementById('jwds');
  if(!w)return;
  if(s&&e&&e>=s){const v=cWDs(s,e);w.textContent=v;w.style.color=v>0?'#1e6bd4':'#dc2626';}
  else{w.textContent='0';w.style.color='#dc2626';}
}

async function saveJob(){
  const pn=document.getElementById('jp')?.value.trim();
  const start=document.getElementById('js')?.value;
  const end=document.getElementById('je')?.value;
  const eEl=document.getElementById('jerr');
  const showErr=msg=>{if(eEl){eEl.textContent=msg;eEl.style.display='block';}};
  if(!pn){showErr('⚠ กรุณากรอกชื่อชิ้นงาน');return;}
  if(!start||!end){showErr('⚠ กรุณาเลือกวันที่');return;}
  if(end<start){showErr('⚠ วันสิ้นสุดต้องไม่ก่อนวันเริ่มต้น');return;}
  if(eEl)eEl.style.display='none';
  const nj={
    jobNo:document.getElementById('jn')?.value.trim()||'',partName:pn,
    drawNo:document.getElementById('jd')?.value.trim()||'',mat:document.getElementById('jm')?.value.trim()||'',
    dia:document.getElementById('ji')?.value.trim()||'',len:document.getElementById('jl')?.value.trim()||'',
    qty:Math.max(1,parseInt(document.getElementById('jq')?.value)||1),
    area:document.getElementById('ja')?.value||'',start,end,
    status:document.getElementById('jst')?.value||'pending',
    notes:document.getElementById('jno')?.value.trim()||'',
  };
  if(_efk&&_eos&&_eos!==start){
    const delta=dD(_eos,start);
    if(delta!==0){
      const aff=jobs.filter(j=>j.fk!==_efk&&j.start>=_eos);
      if(aff.length>0){_pc={fk:_efk,nj,delta,aff};closeM();openCasc();return;}
    }
  }
  await applySave(_efk,nj,null);closeM();
}

async function applySave(fk,nj,casc){
  try{
    if(fk)await JR.child(fk).update(nj);
    else await JR.push({...nj,createdAt:Date.now()});
    if(casc&&casc.aff.length){
      const upd={};
      casc.aff.forEach(j=>{upd[j.fk+'/start']=aD(j.start,casc.delta);upd[j.fk+'/end']=aD(j.end,casc.delta);});
      await JR.update(upd);
    }
  }catch(e){alert('เกิดข้อผิดพลาด: '+e.message);}
}

